#!/bin/bash

CONFIG_DIR="$HOME/.config/seifg"
APP_ID="${SteamAppId:-0}"

if [ -f "$CONFIG_DIR/games/$APP_ID.json" ]; then
    SETTINGS="$CONFIG_DIR/games/$APP_ID.json"
elif [ -f "$CONFIG_DIR/default.json" ]; then
    SETTINGS="$CONFIG_DIR/default.json"
else
    exec "$@"
fi

ENABLED=$(python3 -c "import json; d=json.load(open('$SETTINGS')); print(1 if d.get('enabled') else 0)" 2>/dev/null || echo 0)
MULTIPLIER=$(python3 -c "import json; d=json.load(open('$SETTINGS')); print(min(3, max(2, int(d.get('multiplier', 2)))))" 2>/dev/null || echo 2)
TARGET_FPS=$(python3 -c "import json; d=json.load(open('$SETTINGS')); print(int(d.get('target_fps', 60)))" 2>/dev/null || echo 60)
FLOW_SCALE=$(python3 -c "import json; d=json.load(open('$SETTINGS')); print(min(4, max(1, int(d.get('flow_scale', 1)))))" 2>/dev/null || echo 1)

if [ "$ENABLED" = "1" ] && [ "$MULTIPLIER" -ge 2 ] 2>/dev/null; then
    DXVK_RATE=$(python3 -c "print(max(1, round($TARGET_FPS / $MULTIPLIER)))" 2>/dev/null || echo 30)
    export SEIFG_ENABLE=1
    export VK_INSTANCE_LAYERS=VK_LAYER_SEIFG_frame_generation
    export VK_ADD_IMPLICIT_LAYER_PATH="$HOME/.local/share/vulkan/implicit_layer.d"
    export SEIFG_MULTIPLIER="$MULTIPLIER"
    export SEIFG_FLOW_SCALE="$FLOW_SCALE"
    export DXVK_FRAME_RATE="$DXVK_RATE"
    export VKD3D_FRAME_RATE="$DXVK_RATE"
fi

python3 -c "
import json, os
c = os.path.expanduser('~/.config/fex-emu/Config.json')
os.makedirs(os.path.dirname(c), exist_ok=True)
cfg = {}
if os.path.exists(c):
    cfg = json.load(open(c))
if cfg.get('ThunksDB', {}).get('Vulkan') != 1:
    cfg.setdefault('ThunksDB', {})['Vulkan'] = 1
    json.dump(cfg, open(c, 'w'), indent=2)
" 2>/dev/null

exec "$@"
